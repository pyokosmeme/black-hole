{
  "$schema": "https://developers.cloudflare.com/workers/wrangler/config-schema.json",
  "name": "black-hole",
  "main": "_worker.js",
  "compatibility_date": "2026-05-27",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "149e36b52d1c43518ce7f2d91c22528c"
    }
  ]
}
